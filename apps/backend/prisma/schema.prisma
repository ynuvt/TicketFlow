generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  SERVED
}

enum OrderPriority {
  NORMAL
  HIGH
  VIP
}

model Kitchen {
  id        String          @id @default(uuid())
  name      String          @default("Main Kitchen")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stations  Station[]
  orders    Order[]
  events    OrderEvent[]
  metrics   KitchenMetric[]
}

model Station {
  id           String   @id @default(uuid())
  kitchenId    String
  name         String
  displayOrder Int      @default(0)
  route        String
  isOnline     Boolean  @default(true)
  createdAt    DateTime @default(now())

  kitchen Kitchen @relation(fields: [kitchenId], references: [id], onDelete: Cascade)

  @@index([kitchenId, displayOrder])
}

model Order {
  id                String        @id @default(uuid())
  kitchenId         String
  customerName      String
  priority          OrderPriority @default(NORMAL)
  estimatedPrepTime Int           @default(10)
  status            OrderStatus   @default(PLACED)
  currentStationId  String        @default("intake")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  kitchen    Kitchen      @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  events     OrderEvent[]

  @@index([kitchenId, currentStationId, status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  name      String
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderEvent {
  id             String   @id @default(uuid())
  sequenceNumber BigInt
  kitchenId      String
  orderId        String
  type           String
  payload        Json
  createdAt      DateTime @default(now())

  kitchen Kitchen @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([kitchenId, sequenceNumber])
  @@index([kitchenId, sequenceNumber])
}

model KitchenMetric {
  id                 String   @id @default(uuid())
  kitchenId          String
  date               String
  totalOrders        Int      @default(0)
  completedOrders    Int      @default(0)
  avgPrepTimeMinutes Float    @default(0)
  slaBreaches        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  kitchen Kitchen @relation(fields: [kitchenId], references: [id], onDelete: Cascade)

  @@unique([kitchenId, date])
}
